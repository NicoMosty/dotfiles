#!/usr/bin/env python3
import subprocess
import re

prev_focused = None
buffer = ""

# Start Niri event-stream
proc = subprocess.Popen(["niri", "msg", "event-stream"], stdout=subprocess.PIPE, text=True)

for line in proc.stdout:
    line = line.strip()
    if not line:
        continue

    buffer += line + " "
    # Check if this line ends a Workspaces block
    if "Workspaces changed:" in buffer:
        # Extract focused workspace ID
        matches = re.findall(r"Workspace \{.*?id: (\d+).*?is_focused: true.*?\}", buffer)
        if matches:
            focused_id = matches[0]
            if focused_id != prev_focused:
                prev_focused = focused_id
                # Optional: extract idx and output
                idx_match = re.search(r"idx: (\d+)", buffer)
                out_match = re.search(r'output: Some\("([^"]+)"\)', buffer)
                ws_idx = idx_match.group(1) if idx_match else "?"
                ws_output = out_match.group(1) if out_match else "?"
                msg = f"Workspace ID {focused_id}, idx {ws_idx}, output {ws_output}"
                print(f"Focused workspace changed: {msg}")
                subprocess.run(["notify-send", "Workspace switched", msg])
        buffer = ""  # Reset buffer after processing
