// You can configure outputs by their name, which you can find
// by running `niri msg outputs` while inside a niri instance.

{{- if eq .device "Laptop" }}
output "eDP-1" {
    mode "1920x1080"
    scale 1.0
    transform "normal"
    position x=0 y=1080
}

output "HDMI-A-1" {
    mode "1920x1080"
    scale 1.0
    transform "normal"
    position x=0 y=0
}
{{- else if eq .device "UltraWide" }}
output "DP-2" {
    mode "3440x1440"
    scale 1
    transform "normal"
    position x=0 y=0
}

output "HDMI-A-1" {
    mode "1920x1080"
    scale 1
    transform "normal"
    position x=760 y=1440
}
{{- end }}
