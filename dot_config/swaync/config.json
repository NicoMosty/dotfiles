{
  "$schema": "/etc/xdg/swaync/config.schema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "top",
  "cssPriority": "user",
  "control-center-margin-top": 20,
  "control-center-margin-bottom": 20,
  "control-center-margin-right": 20,
  "control-center-margin-left": 20,
  "notification-margin-top": 20,
  "notification-margin-bottom": 20,
  "notification-margin-right": 20,
  "notification-margin-left": 20,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "image-visibility": "always",
  "transition-time": 200,
  "hide-on-clear": true,
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 12
    }
  }
}
